# Maintainer: Antidote1911 <antidote1911@gmail.com>
pkgname=deadpool
pkgver=1.6.3
pkgrel=1
pkgdesc="Strong random password generator (CLI + GUI)"
arch=('x86_64')
url="https://github.com/Antidote1911/deadpool"
license=('MIT')
depends=('gcc-libs' 'libxcb' 'libxkbcommon' 'fontconfig' 'mesa' 'gtk3')
makedepends=('rust' 'pkg-config')
source=("deadpool-${pkgver}.tar.gz::https://github.com/Antidote1911/deadpool/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "deadpool-${pkgver}"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "deadpool-${pkgver}"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --release --locked -p deadpool-cli -p deadpool
}

package() {
  cd "deadpool-${pkgver}"
  install -Dm755 target/release/deadpool-cli "${pkgdir}/usr/bin/deadpool-cli"
  install -Dm755 target/release/deadpool     "${pkgdir}/usr/bin/deadpool"
  install -Dm644 deadpool-gui/resources/icon.png \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/deadpool.png"

  install -d "${pkgdir}/usr/share/applications"
  cat > "${pkgdir}/usr/share/applications/deadpool.desktop" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Deadpool Password Generator
Exec=deadpool
Icon=deadpool
Categories=Utility;
Comment=Strong password generator
EOF
  chmod 644 "${pkgdir}/usr/share/applications/deadpool.desktop"

  install -Dm644 LICENSE-MIT "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md   "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
